# ==============================================================================
# LIFE-IN-DATA: Przykładowy plik konfiguracyjny środowiska
# Skopiuj ten plik do .env i uzupełnij wartościami specyficznymi dla Twojej maszyny.
# ==============================================================================

# Ścieżka bazowa do surowych danych wewnątrz kontenera.
# W Dockerze odpowiada ona punktowi montowania wolumenu dla Google Drive.
# Domyślnie: /app/gdrive_raw
RAW_DATA_ROOT=/app/gdrive_raw

# Pozwala Pythonowi widzieć moduły wewnątrz folderu /src bez dodatkowych flag.
# Wartość: .
PYTHONPATH=.

# Poziom logowania dla całego rurociągu ETL.
# Opcje: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Wskazówka: Jeśli uruchamiasz to poza Dockerem (lokalnie w venv), 
# zmień RAW_DATA_ROOT na fizyczną ścieżkę do GDrive, np.:
# RAW_DATA_ROOT=/mnt/g/Mój dysk/Dokumenty/Me, Myself & I